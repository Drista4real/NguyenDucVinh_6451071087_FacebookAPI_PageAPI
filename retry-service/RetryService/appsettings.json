{
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "SendFailedTopic": "send_failed",
    "SendRetryTopic": "send_retry",
    "DeadLetterTopic": "dead_letter",
    "GroupId": "retry-service-group",
    "AutoOffsetReset": "Earliest",
    "MaxRetries": 3,
    "BaseDelaySeconds": 1,
    "MaxDelaySeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
